      ],
      "parameters": {
        "jsCode": "let t=$input.all().map(i=>i.json); t=(t.length===1&&Array.isArray(t[0]))?t[0]:t;\nconst d=new Date(),pad=n=>String(n).padStart(2,'0');\nconst fmt=z=>z.getUTCFullYear()+'-'+pad(z.getUTCMonth()+1)+'-'+pad(z.getUTCDate());\nconst today=fmt(d),tomorrow=fmt(new Date(d.getTime()+86400000));\nlet slugs=t.map(x=>x.tenant_id); if(!slugs.length) slugs=['__none__'];\nreturn [{json:{tenants:t,slugs,today,tomorrow}}];"
      }
