    {
      "id": "Compute",
      "name": "Compute",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2600,
        0
      ],
      "parameters": {
        "jsCode": "\nconst A=$input.first().json;\nconst LOW_GRAMS=100; // configurable low fine-gold threshold per karat\nconst today=A.today, tomorrow=A.tomorrow;\nconst grp=(arr)=>{const m={};for(const r of (arr||[])){if(!r||!r.tenant_id)continue;(m[r.tenant_id]=m[r.tenant_id]||[]).push(r);}return m;};\nconst S=grp(A.sales),G=grp(A.gold),O=grp(A.orders),I=grp(A.items),SI=grp(A.saleitems);\nconst r2=n=>Math.round(n*100)/100, r3=n=>Math.round(n*1000)/1000;\nconst out=[];\nfor(const t of (A.tenants||[])){\n  const slug=t.tenant_id, cur=t.currency||'PKR';\n  const sales=S[slug]||[], gold=G[slug]||[], orders=O[slug]||[], items=I[slug]||[], sitems=SI[slug]||[];\n  const cash_today=r2(sales.reduce((s,x)=>s+(Number(x.paid_cash)||0),0));\n  const sales_total=r2(sales.reduce((s,x)=>s+(Number(x.net_bill)||0),0));\n  const sales_count=sales.length;\n  const pos={}; for(const g of gold){const k=g.karat==null?'?':g.karat; pos[k]=(pos[k]||0)+(Number(g.fine_grams)||0);} for(const k in pos) pos[k]=r3(pos[k]);\n  const due=orders.filter(o=>o.delivery_date&&String(o.delivery_date).slice(0,10)<=tomorrow).map(o=>({order_no:o.order_no,delivery:String(o.delivery_date).slice(0,10),balance:Number(o.balance)||0,status:o.status}));\n  const low=Object.keys(pos).filter(k=>pos[k]<LOW_GRAMS).map(k=>({karat:k,fine_grams:pos[k]}));\n  const vel={}; for(const si of sitems){const tag=si.tag_number||'?'; vel[tag]=(vel[tag]||0)+1;}\n  const top=Object.entries(vel).sort((a,b)=>b[1]-a[1]).slice(0,3).map(([tag,n])=>({tag,sold:n}));\n  const soldTags=new Set(Object.keys(vel));\n  const slow=items.filter(it=>!soldTags.has(it.tag_number)).slice(0,3).map(it=>({tag:it.tag_number,karat:it.karat,collection:it.group_item}));\n  const restock=low.length?(\"Low fine-gold stock at \"+low.map(l=>l.karat+'K ('+l.fine_grams+'g)').join(', ')+\" \u2014 consider restocking.\"):(top.length?(\"Best seller \"+top[0].tag+\" (\"+top[0].sold+\" sold) \u2014 keep it stocked.\"):\"Stock levels look healthy.\");\n  const posStr=Object.keys(pos).length?Object.entries(pos).map(([k,v])=>k+'K '+v+'g').join(', '):'0g';\n  const dueStr=due.length?due.map(d=>d.order_no+' '+d.delivery+(d.balance?(' bal '+cur+' '+d.balance):'')).join('; '):'none';\n  const msg=\"Legacy Jewellers \u2014 Daily Snapshot (\"+today+\")\\n\"+\n    \"Cash today: \"+cur+\" \"+cash_today+\"\\n\"+\n    \"Sales: \"+sales_count+\" (\"+cur+\" \"+sales_total+\")\\n\"+\n    \"Gold position: \"+posStr+\"\\n\"+\n    \"Orders due by tomorrow: \"+dueStr+\"\\n\"+\n    \"Restock: \"+restock;\n  out.push({json:{tenant_id:slug, snapshot:{date:today,cash_today,sales_count,sales_total,gold_position:pos,orders_due:due,low_stock:low,top_sellers:top,slow_movers:slow,restock}, whatsapp_payload:{to:(t.phone||null),phone_number_id:null,messaging_product:'whatsapp',type:'text',text:{body:msg}}, broadcast_enabled:false, sent:false}});\n}\nreturn out.length?out:[{json:{note:'no jewellery tenants',broadcast_enabled:false,sent:false}}];\n"
      }
