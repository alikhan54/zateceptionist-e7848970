        "url": "=https://fncfbywkemsxwuiowxxe.supabase.co/rest/v1/jx_order?tenant_id=eq.{{ $json.tenant }}{{ $json.order_no ? '&order_no=eq.'+$json.order_no : '' }}&select=order_no,status,delivery_date,net_amount,balance&order=created_at.desc&limit=5",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "options": {}
      },
      "credentials": {
        "supabaseApi": {
          "id": "gQE27pII1aZEzHbn",
