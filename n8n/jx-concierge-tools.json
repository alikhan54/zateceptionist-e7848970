        "jsCode": "const p=$('BA Parse').item.json;\nlet rows=$input.all().map(i=>i.json); rows=(rows.length===1&&Array.isArray(rows[0]))?rows[0]:rows;\nconst id=(rows[0]&&rows[0].id)||null;\nconst result=\"Thank you, \"+(p.name||'there')+\"! I've noted your request\"+(p.preferred?(\" for \"+p.preferred):\"\")+\" and our team at Legacy Jewellers will contact you on \"+(p.phone||'your number')+\" to confirm.\";\nreturn [{json:{results:[{toolCallId:p.toolCallId,result}],tenant:p.tenant,customer_id:id,booked:true}}];"
