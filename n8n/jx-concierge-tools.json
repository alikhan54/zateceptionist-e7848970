      "name": "OS Format",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        240
      ],
      "parameters": {
        "jsCode": "const p=$('OS Parse').item.json;\nlet rows=$input.all().map(i=>i.json); rows=(rows.length===1&&Array.isArray(rows[0]))?rows[0]:rows;\nrows=rows.filter(r=>r&&r.order_no);\nlet result; if(!rows.length){result=\"I couldn't find an order with those details \u2014 please check the order number.\";}\nelse{const o=rows[0];const dd=o.delivery_date?(\" Expected delivery: \"+String(o.delivery_date).slice(0,10)+\".\"):\"\";result=\"Order \"+o.order_no+\" status: \"+o.status+\".\"+dd+(o.balance!=null?(\" Balance: PKR \"+o.balance+\".\"):\"\");}\nreturn [{json:{results:[{toolCallId:p.toolCallId,result}],tenant:p.tenant,orders:rows}}];"
