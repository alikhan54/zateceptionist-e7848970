      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        0
      ],
      "parameters": {
        "jsCode": "const b=$json.body||{},q=$json.query||{};\nconst tc=(b.message&&b.message.toolCalls&&b.message.toolCalls[0])||null;\nlet a={}; if(tc&&tc.function){try{a=typeof tc.function.arguments==='string'?JSON.parse(tc.function.arguments):(tc.function.arguments||{});}catch(e){a={};}}\nconst g=(k)=>String(q[k]!=null?q[k]:(b[k]!=null?b[k]:(a[k]!=null?a[k]:''))).trim();\nconst toolCallId=(tc&&tc.id)||b.toolCallId||'test';\nreturn [{json:{tenant:g('tenant'),karat:g('karat'),toolCallId}}];"
      }
    },
    {
      "id": "GR Fetch",
      "name": "GR Fetch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://fncfbywkemsxwuiowxxe.supabase.co/rest/v1/jx_gold_rate?tenant_id=eq.{{ $json.tenant }}{{ $json.karat ? '&karat=eq.'+$json.karat : '' }}&select=karat,rate_per_gram,rate_per_tola,source&order=karat.asc",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "options": {}
      },
      "credentials": {
        "supabaseApi": {
          "id": "gQE27pII1aZEzHbn",
          "name": "ZATECEPTIONIST-V2"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "alwaysOutputData": true
    },
    {
      "id": "GR Format",
      "name": "GR Format",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        0
      ],
      "parameters": {
        "jsCode": "const p=$('GR Parse').item.json;\nlet rows=$input.all().map(i=>i.json); rows=(rows.length===1&&Array.isArray(rows[0]))?rows[0]:rows;\nrows=rows.filter(r=>r&&r.karat!=null);\nlet result; if(!rows.length){result=\"I don't have a current gold rate on file to share right now.\";}\nelse{result=\"Today's gold rate \u2014 \"+rows.map(r=>r.karat+\"K: PKR \"+r.rate_per_gram+\"/g (PKR \"+r.rate_per_tola+\"/tola)\").join('; ')+\".\";}\nreturn [{json:{results:[{toolCallId:p.toolCallId,result}],tenant:p.tenant,rates:rows}}];"
      }
    },
    {
      "id": "GR Respond",
